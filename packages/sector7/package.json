{
	"name": "@jmmaloney4/sector7",
	"version": "0.7.0",
	"description": "Reusable Pulumi components for infrastructure management",
	"license": "MPL-2.0",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"engines": {
		"node": ">=24.0.0"
	},
	"exports": {
		".": {
			"types": "./index.ts",
			"default": "./index.ts"
		},
		"./access": {
			"types": "./access/index.ts",
			"default": "./access/index.ts"
		},
		"./iam": {
			"types": "./iam/index.ts",
			"default": "./iam/index.ts"
		},
		"./workersite": {
			"types": "./workersite/index.ts",
			"default": "./workersite/index.ts"
		},
		"./r2": {
			"types": "./r2/index.ts",
			"default": "./r2/index.ts"
		},
		"./nix-image": {
			"types": "./nix-image/index.ts",
			"default": "./nix-image/index.ts"
		},
		"./scripts": {
			"types": "./scripts/index.ts",
			"default": "./scripts/index.ts"
		}
	},
	"files": [
		"index.ts",
		"access",
		"iam",
		"workersite",
		"r2",
		"nix-image",
		"scripts"
	],
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"peerDependencies": {
		"@pulumi/pulumi": "^3.0.0",
		"@pulumi/cloudflare": "^6.0.0",
		"@pulumi/gcp": "^9.0.0",
		"@pulumi/command": "^1.0.0"
	},
	"devDependencies": {
		"@pulumi/pulumi": "3.230.0",
		"@pulumi/cloudflare": "6.14.0",
		"@pulumi/gcp": "9.19.0",
		"@pulumi/command": "1.2.1",
		"vitest": "4.1.2"
	}
}
