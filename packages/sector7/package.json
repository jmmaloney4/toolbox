{
	"name": "@jmmaloney4/sector7",
	"version": "0.6.0",
	"description": "Reusable Pulumi components for infrastructure management",
	"license": "MPL-2.0",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"engines": {
		"node": ">=24.0.0"
	},
	"exports": {
		".": {
			"types": "./index.ts",
			"default": "./index.ts"
		},
		"./iam": {
			"types": "./iam/index.ts",
			"default": "./iam/index.ts"
		},
		"./workersite": {
			"types": "./workersite/index.ts",
			"default": "./workersite/index.ts"
		}
	},
	"files": [
		"index.ts",
		"iam",
		"workersite"
	],
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"peerDependencies": {
		"@pulumi/pulumi": "^3.0.0",
		"@pulumi/cloudflare": "^6.0.0",
		"@pulumi/gcp": "^9.0.0",
		"@aws-sdk/client-s3": "^3.0.0"
	},
	"peerDependenciesMeta": {
		"@aws-sdk/client-s3": {
			"optional": true
		}
	},
	"devDependencies": {
		"@pulumi/pulumi": "3.213.0",
		"@pulumi/cloudflare": "6.11.0",
		"@pulumi/gcp": "9.6.0",
		"vitest": "4.1.2"
	}
}
