{
	"compilerOptions": {
		"target": "ES2020",
		"module": "CommonJS",
		"moduleResolution": "Node",
		"declaration": true,
		"outDir": "dist",
		"rootDir": ".",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true
	},
	"include": ["index.ts", "iam/**/*.ts", "workersite/**/*.ts"],
	"exclude": ["dist/**", "node_modules/**", "tests/**/*.ts"]
}
